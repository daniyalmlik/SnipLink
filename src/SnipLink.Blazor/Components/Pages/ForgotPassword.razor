@page "/forgot-password"
@layout SnipLink.Blazor.Components.Layout.MinimalLayout
@inject SnipLinkApiClient Api
@inject NavigationManager Nav

<PageTitle>Forgot Password &mdash; SnipLink</PageTitle>

<div class="login-container">
    <RadzenCard class="login-card">
        <h2>Reset your password</h2>

        @if (sent)
        {
            <RadzenAlert AlertStyle="AlertStyle.Success" ShowIcon="false" class="rz-mb-3">
                A password reset link has been sent. Check your inbox.
            </RadzenAlert>
            <p class="auth-footer-text">
                <a href="/login" class="auth-toggle-link">Back to sign in</a>
            </p>
        }
        else
        {
            @if (noAccountFound)
            {
                <RadzenAlert AlertStyle="AlertStyle.Danger" ShowIcon="false" class="rz-mb-3">
                    No account exists with this email. <a href="/register" class="auth-toggle-link">Create one here.</a>
                </RadzenAlert>
            }
            else if (errorMessage is not null)
            {
                <RadzenAlert AlertStyle="AlertStyle.Danger" ShowIcon="false" class="rz-mb-3">
                    @errorMessage
                </RadzenAlert>
            }

            <p style="color:#6b7280;font-size:14px;margin-bottom:1.25rem">
                Enter your email address and we'll send you a link to reset your password.
            </p>

            <RadzenTemplateForm TItem="FormModel" Data="@model" Submit="@HandleSubmit">
                <RadzenFormField Text="Email" class="rz-w-100 rz-mb-4">
                    <RadzenTextBox @bind-Value="@model.Email"
                                   Placeholder="you@example.com"
                                   InputType="InputType.Email"
                                   class="rz-w-100" />
                </RadzenFormField>

                <RadzenButton ButtonType="ButtonType.Submit"
                              Text="Send reset link"
                              ButtonStyle="ButtonStyle.Primary"
                              class="rz-w-100 rz-mb-3"
                              IsBusy="@isLoading" />
            </RadzenTemplateForm>

            <p class="auth-footer-text">
                <a href="/login" class="auth-toggle-link">Back to sign in</a>
            </p>
        }
    </RadzenCard>
</div>

@code {
    private bool isLoading;
    private bool sent;
    private bool noAccountFound;
    private string? errorMessage;
    private readonly FormModel model = new();

    private async Task HandleSubmit()
    {
        errorMessage = null;
        noAccountFound = false;
        isLoading = true;
        StateHasChanged();

        try
        {
            var error = await Api.ForgotPasswordAsync(model.Email);
            if (error is not null)
            {
                if (error.Contains("No account found", StringComparison.OrdinalIgnoreCase))
                    noAccountFound = true;
                else
                    errorMessage = error;
            }
            else
                sent = true;
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private class FormModel
    {
        public string Email { get; set; } = string.Empty;
    }
}
