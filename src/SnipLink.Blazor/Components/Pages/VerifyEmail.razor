@page "/verify-email"
@layout SnipLink.Blazor.Components.Layout.MinimalLayout
@inject SnipLinkApiClient Api
@inject NavigationManager Nav

<PageTitle>Verify Email &mdash; SnipLink</PageTitle>

<div class="login-container">
    <RadzenCard class="login-card">
        <h2>Email Verification</h2>

        @if (isLoading)
        {
            <p style="text-align:center;color:#6b7280">Verifying your email address&hellip;</p>
        }
        else if (success)
        {
            <RadzenAlert AlertStyle="AlertStyle.Success" ShowIcon="false" class="rz-mb-4">
                Your email has been verified successfully. You can now sign in.
            </RadzenAlert>
            <RadzenButton Text="Sign in"
                          ButtonStyle="ButtonStyle.Primary"
                          class="rz-w-100"
                          Click="@(() => Nav.NavigateTo("/login"))" />
        }
        else
        {
            <RadzenAlert AlertStyle="AlertStyle.Danger" ShowIcon="false" class="rz-mb-4">
                @errorMessage
            </RadzenAlert>
            <p class="auth-footer-text">
                <a href="/register" class="auth-toggle-link">Register again</a>
            </p>
        }
    </RadzenCard>
</div>

@code {
    [SupplyParameterFromQuery] private string? UserId { get; set; }
    [SupplyParameterFromQuery] private string? Token  { get; set; }

    private bool isLoading = true;
    private bool success;
    private string errorMessage = "Verification failed. The link may be invalid or expired.";

    protected override async Task OnInitializedAsync()
    {
        if (string.IsNullOrWhiteSpace(UserId) || string.IsNullOrWhiteSpace(Token))
        {
            errorMessage = "Invalid verification link.";
            isLoading = false;
            return;
        }

        var (ok, error) = await Api.VerifyEmailAsync(UserId, Token);
        success      = ok;
        errorMessage = error ?? errorMessage;
        isLoading    = false;
    }
}
