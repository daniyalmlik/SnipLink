@page "/reset-password"
@layout SnipLink.Blazor.Components.Layout.MinimalLayout
@inject SnipLinkApiClient Api
@inject NavigationManager Nav

<PageTitle>Reset Password &mdash; SnipLink</PageTitle>

<div class="login-container">
    <RadzenCard class="login-card">
        <h2>Choose a new password</h2>

        @if (success)
        {
            <RadzenAlert AlertStyle="AlertStyle.Success" ShowIcon="false" class="rz-mb-3">
                Your password has been reset successfully.
            </RadzenAlert>
            <p class="auth-footer-text">
                <a href="/login" class="auth-toggle-link">Sign in with your new password</a>
            </p>
        }
        else if (invalidLink)
        {
            <RadzenAlert AlertStyle="AlertStyle.Danger" ShowIcon="false" class="rz-mb-3">
                This password reset link is invalid or has expired. Please request a new one.
            </RadzenAlert>
            <p class="auth-footer-text">
                <a href="/forgot-password" class="auth-toggle-link">Request a new reset link</a>
            </p>
        }
        else
        {
            @if (errorMessage is not null)
            {
                <RadzenAlert AlertStyle="AlertStyle.Danger" ShowIcon="false" class="rz-mb-3">
                    @errorMessage
                </RadzenAlert>
            }

            <RadzenTemplateForm TItem="FormModel" Data="@model" Submit="@HandleSubmit">
                <div class="rz-w-100 rz-mb-3">
                    <label class="field-label">New Password</label>
                    <div class="password-wrapper">
                        <input type="@(showPassword ? "text" : "password")"
                               @bind="@model.NewPassword"
                               @bind:event="oninput"
                               placeholder="At least 12 characters"
                               class="rz-textbox rz-w-100 password-input" />
                        <button type="button" class="eye-toggle" @onclick="TogglePassword" tabindex="-1">
                            @if (showPassword)
                            {
                                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94"/>
                                    <path d="M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19"/>
                                    <line x1="1" y1="1" x2="23" y2="23"/>
                                </svg>
                            }
                            else
                            {
                                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
                                    <circle cx="12" cy="12" r="3"/>
                                </svg>
                            }
                        </button>
                    </div>
                </div>

                <div class="rz-w-100 rz-mb-4">
                    <label class="field-label">Confirm Password</label>
                    <div class="password-wrapper">
                        <input type="@(showConfirm ? "text" : "password")"
                               @bind="@model.ConfirmPassword"
                               @bind:event="oninput"
                               placeholder="Repeat new password"
                               class="rz-textbox rz-w-100 password-input" />
                        <button type="button" class="eye-toggle" @onclick="ToggleConfirm" tabindex="-1">
                            @if (showConfirm)
                            {
                                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94"/>
                                    <path d="M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19"/>
                                    <line x1="1" y1="1" x2="23" y2="23"/>
                                </svg>
                            }
                            else
                            {
                                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
                                    <circle cx="12" cy="12" r="3"/>
                                </svg>
                            }
                        </button>
                    </div>
                </div>

                <RadzenButton ButtonType="ButtonType.Submit"
                              Text="Reset password"
                              ButtonStyle="ButtonStyle.Primary"
                              class="rz-w-100 rz-mb-3"
                              IsBusy="@isLoading" />
            </RadzenTemplateForm>
        }
    </RadzenCard>
</div>

@code {
    [SupplyParameterFromQuery] private string? UserId { get; set; }
    [SupplyParameterFromQuery] private string? Token { get; set; }

    private bool isLoading;
    private bool success;
    private bool invalidLink;
    private bool showPassword;
    private bool showConfirm;
    private string? errorMessage;
    private readonly FormModel model = new();

    protected override void OnInitialized()
    {
        if (string.IsNullOrWhiteSpace(UserId) || string.IsNullOrWhiteSpace(Token))
            invalidLink = true;
    }

    private void TogglePassword() => showPassword = !showPassword;
    private void ToggleConfirm() => showConfirm = !showConfirm;

    private async Task HandleSubmit()
    {
        errorMessage = null;

        if (model.NewPassword != model.ConfirmPassword)
        {
            errorMessage = "Passwords do not match.";
            return;
        }

        if (string.IsNullOrWhiteSpace(UserId) || string.IsNullOrWhiteSpace(Token))
        {
            invalidLink = true;
            return;
        }

        isLoading = true;
        StateHasChanged();

        try
        {
            var (ok, error) = await Api.ResetPasswordAsync(UserId, Token, model.NewPassword);
            if (ok)
                success = true;
            else
                errorMessage = error;
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private class FormModel
    {
        public string NewPassword { get; set; } = string.Empty;
        public string ConfirmPassword { get; set; } = string.Empty;
    }
}
