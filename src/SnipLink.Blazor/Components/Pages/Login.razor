@page "/login"
@layout SnipLink.Blazor.Components.Layout.MinimalLayout
@inject AuthStateService AuthState
@inject NavigationManager Nav
@inject SnipLinkApiClient Api
@implements IDisposable

<PageTitle>Sign In &mdash; SnipLink</PageTitle>

<div class="login-container">
    <RadzenCard class="login-card">
        <h2>Welcome back</h2>

        @if (errorMessage is not null)
        {
            <RadzenAlert AlertStyle="AlertStyle.Danger" ShowIcon="false" class="rz-mb-3">
                @errorMessage
            </RadzenAlert>
        }

        @if (showUnverifiedBanner)
        {
            <RadzenAlert AlertStyle="AlertStyle.Warning" ShowIcon="false" class="rz-mb-3">
                Your email is not verified yet.
                @if (resendLoading)
                {
                    <span> Sending...</span>
                }
                else if (resendSent)
                {
                    <span> Verification email resent — check your inbox.</span>
                }
                else
                {
                    <span> <a href="#" class="auth-toggle-link" @onclick="HandleResend" @onclick:preventDefault>Click here to resend the verification email.</a></span>
                }
            </RadzenAlert>
            @if (resendError is not null)
            {
                <RadzenAlert AlertStyle="AlertStyle.Danger" ShowIcon="false" class="rz-mb-2">
                    @resendError
                </RadzenAlert>
            }
        }

        <RadzenTemplateForm TItem="FormModel" Data="@model" Submit="@HandleSubmit">
            <RadzenFormField Text="Email" class="rz-w-100 rz-mb-3">
                <RadzenTextBox @bind-Value="@model.Email" Placeholder="you@example.com" InputType="InputType.Email" class="rz-w-100" />
            </RadzenFormField>

            <div class="rz-w-100 rz-mb-4">
                <label class="field-label">Password</label>
                <div class="password-wrapper">
                    <input type="@(showPassword ? "text" : "password")"
                           @bind="@model.Password"
                           @bind:event="oninput"
                           placeholder="Password"
                           class="rz-textbox rz-w-100 password-input" />
                    <button type="button" class="eye-toggle" @onclick="TogglePassword" tabindex="-1">
                        @if (showPassword)
                        {
                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94"/>
                                <path d="M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19"/>
                                <line x1="1" y1="1" x2="23" y2="23"/>
                            </svg>
                        }
                        else
                        {
                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
                                <circle cx="12" cy="12" r="3"/>
                            </svg>
                        }
                    </button>
                </div>
            </div>

            <RadzenButton ButtonType="ButtonType.Submit"
                          Text="@(cooldownSeconds > 0 ? $"Wait {cooldownSeconds}s\u2026" : "Sign In")"
                          ButtonStyle="ButtonStyle.Primary"
                          class="rz-w-100 rz-mb-3"
                          Disabled="@(cooldownSeconds > 0)"
                          IsBusy="@isLoading" />
        </RadzenTemplateForm>

        <p class="auth-footer-text">
            <span>No account? </span>
            <a href="/register" class="auth-toggle-link">Create one</a>
        </p>
    </RadzenCard>
</div>

@code {
    private bool isLoading;
    private bool showPassword;
    private bool showUnverifiedBanner;
    private bool resendLoading;
    private bool resendSent;
    private string? resendError;
    private string? errorMessage;
    private int failedAttempts;
    private int cooldownSeconds;
    private System.Threading.Timer? _cooldownTimer;
    private readonly FormModel model = new();

    protected override void OnInitialized()
    {
        if (AuthState.IsAuthenticated)
            Nav.NavigateTo("/dashboard");
    }

    private void TogglePassword() => showPassword = !showPassword;

    private async Task HandleResend()
    {
        resendError = null;
        resendSent  = false;
        resendLoading = true;
        StateHasChanged();
        try
        {
            var err = await Api.ResendVerificationAsync(model.Email);
            if (err is not null) resendError = err;
            else resendSent = true;
        }
        finally
        {
            resendLoading = false;
            StateHasChanged();
        }
    }

    private async Task HandleSubmit()
    {
        errorMessage = null;
        showUnverifiedBanner = false;
        resendSent = false;
        resendError = null;
        isLoading = true;
        StateHasChanged();

        try
        {
            var error = await AuthState.LoginAsync(new LoginRequest
            {
                Email = model.Email,
                Password = model.Password
            });

            if (error is not null)
            {
                failedAttempts++;
                if (error.Contains("verify your email", StringComparison.OrdinalIgnoreCase))
                {
                    showUnverifiedBanner = true;
                }
                else
                {
                    errorMessage = error;
                }
                ApplyCooldownIfNeeded();
                StateHasChanged();
                return;
            }

            failedAttempts = 0;
            Nav.NavigateTo("/dashboard");
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private void ApplyCooldownIfNeeded()
    {
        if (failedAttempts < 5) return;
        cooldownSeconds = (failedAttempts - 4) * 30;
        _cooldownTimer?.Dispose();
        _cooldownTimer = new System.Threading.Timer(_ =>
        {
            if (cooldownSeconds > 0)
            {
                cooldownSeconds--;
                InvokeAsync(StateHasChanged);
            }
            else
            {
                _cooldownTimer?.Dispose();
            }
        }, null, TimeSpan.FromSeconds(1), TimeSpan.FromSeconds(1));
    }

    public void Dispose() => _cooldownTimer?.Dispose();

    private class FormModel
    {
        public string Email { get; set; } = string.Empty;
        public string Password { get; set; } = string.Empty;
    }
}
