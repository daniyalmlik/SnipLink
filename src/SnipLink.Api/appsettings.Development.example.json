{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=sniplink.db"
  },
  "Analytics": {
    "IpHashSalt": "replace-with-a-long-random-secret"
  },
  "Cors": {
    "AllowedOrigin": "https://localhost:7129"
  },
  "Frontend": {
    "BaseUrl": "https://localhost:7129"
  },
  "Email": {
    "From": "noreply@example.com",
    "FromName": "SnipLink",
    "Host": "smtp.example.com",
    "Port": 587,
    "UseSsl": false,
    "Username": "smtp-username",
    "Password": "smtp-password"
  },
  "Resend": {
    "ApiKey": "re_your_resend_api_key"
  }
}
